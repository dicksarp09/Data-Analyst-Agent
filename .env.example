# Phase 0 & 1
CORRELATION_THRESHOLD=0.6
Z_SCORE_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
MIN_ROWS_FOR_CLUSTERING=50
MAX_CLUSTERS=5
SHIFT_THRESHOLD=0.3
ROLLING_WINDOW=5
MAX_SIGNALS=50

# Phase 2
HYPOTHESIS_MAX_COUNT=10
HYPOTHESIS_EXPANSION_DEPTH=2

# Phase 3
MAX_ITERATIONS=5
ACCEPT_THRESHOLD=0.75
REJECT_THRESHOLD=0.30

# Phase 4
MIN_CONFIDENCE_TO_REPORT=0.6
HIGH_CONFIDENCE_THRESHOLD=0.75
ENABLE_PLOT_GENERATION=true
MAX_PLOTS_PER_HYPOTHESIS=3
ALLOW_CHAT_ONLY_FROM_INSIGHTS=true
ENABLE_MULTI_PLOT_MODE=true
FORBID_UNLINKED_PLOTS=true

# GROQ LLM (optional)
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Security (production hardening)
FORBID_UNLINKED_PLOTS=true

# Reliability
CIRCUIT_BREAKER_FAILURES=3
CIRCUIT_BREAKER_TIMEOUT=60
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0

# Langfuse Observability (optional - enables tracing)
# Get keys from https://cloud.langfuse.com -> Settings -> API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com  # or https://us.cloud.langfuse.com

# Monitoring & Logging
LOG_DIR=logs
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
APP_VERSION=1.0.0

# Rate Limiting
RATE_LIMIT_RPM=60  # Requests per minute
RATE_LIMIT_BURST=10  # Burst allowance